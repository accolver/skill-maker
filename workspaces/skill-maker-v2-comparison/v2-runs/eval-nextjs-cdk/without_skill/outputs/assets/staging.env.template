# Next.js CDK Deploy — Staging Environment Config
# Copy this to config/staging.env and fill in your values.

# === AWS Infrastructure ===
AWS_ACCOUNT_ID=111111111111
AWS_REGION=us-east-1

# === Domain & TLS ===
DOMAIN_NAME=staging.example.com
CERTIFICATE_ARN=arn:aws:acm:us-east-1:111111111111:certificate/REPLACE_ME

# === Scaling ===
MIN_INSTANCES=1
MAX_INSTANCES=5

# === Logging ===
LOG_LEVEL=debug

# === Build-Time Client Variables (NEXT_PUBLIC_) ===
# These are baked into the JS bundle at build time.
# Changing them requires a rebuild.
NEXT_PUBLIC_API_URL=https://api-staging.example.com
NEXT_PUBLIC_STAGE=staging

# === Runtime Server Variables ===
# These are set as Lambda environment variables.
# They can be changed without rebuilding.
# DATABASE_URL=postgresql://user:pass@staging-db.example.com:5432/myapp
# REDIS_URL=redis://staging-redis.example.com:6379
# SESSION_SECRET=your-staging-secret
