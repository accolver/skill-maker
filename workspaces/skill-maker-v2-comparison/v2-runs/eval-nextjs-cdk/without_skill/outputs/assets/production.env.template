# Next.js CDK Deploy — Production Environment Config
# Copy this to config/production.env and fill in your values.

# === AWS Infrastructure ===
AWS_ACCOUNT_ID=222222222222
AWS_REGION=us-east-1

# === Domain & TLS ===
DOMAIN_NAME=www.example.com
CERTIFICATE_ARN=arn:aws:acm:us-east-1:222222222222:certificate/REPLACE_ME

# === Scaling ===
MIN_INSTANCES=3
MAX_INSTANCES=50

# === Logging ===
LOG_LEVEL=warn

# === Build-Time Client Variables (NEXT_PUBLIC_) ===
# These are baked into the JS bundle at build time.
# Changing them requires a rebuild.
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_STAGE=production

# === Runtime Server Variables ===
# These are set as Lambda environment variables.
# They can be changed without rebuilding.
# DATABASE_URL=postgresql://user:pass@production-db.example.com:5432/myapp
# REDIS_URL=redis://production-redis.example.com:6379
# SESSION_SECRET=your-production-secret-use-a-strong-random-value
