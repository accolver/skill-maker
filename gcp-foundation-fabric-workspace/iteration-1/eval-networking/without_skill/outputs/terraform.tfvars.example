# Example variable values for Hub-and-Spoke Networking
# Copy this file to terraform.tfvars and fill in your values.

project_id      = "my-networking-project"
organization_id = "123456789012"
billing_account = "AAAAAA-BBBBBB-CCCCCC"
prefix          = "myorg"

# Override subnet CIDRs if needed:
