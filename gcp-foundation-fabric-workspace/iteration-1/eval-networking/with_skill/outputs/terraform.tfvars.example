# Example variable values for hub-and-spoke networking topology.
# Copy to terraform.tfvars and fill in your values.

billing_account = "012345-ABCDEF-012345"
organization_id = 123456789012
parent          = "folders/1234567890"
prefix          = "myco-gcp"

region_primary   = "europe-west1"
region_secondary = "us-central1"
region_tertiary  = "asia-southeast1"

labels = {
  environment = "networking"
  managed-by  = "terraform"
  team        = "platform"
}
