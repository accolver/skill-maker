      "Output contains --scope=organizations/998877",
      "Output contains container.googleapis.com/Cluster",
      "Output contains env=prod",
      "Output contains --format=json",
      "Output matches regex jq|json\\(",
      "Output does not contain delete",
      "Output does not contain resize"
    ],
    "checks": [
      {
        "type": "contains",
        "value": "gcloud asset search-all-resources"
      },
      {
        "type": "contains",
        "value": "--scope=organizations/998877"
      },
      {
        "type": "contains",
        "value": "container.googleapis.com/Cluster"
      },
      {
        "type": "contains",
        "value": "env=prod"
      },
      {
        "type": "contains",
        "value": "--format=json"
      },
      {
        "type": "regex",
        "pattern": "jq|json\\(",
